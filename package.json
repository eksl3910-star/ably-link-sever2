{
  "name": "ably-link-sever2",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "pages:build": "node ./node_modules/@cloudflare/next-on-pages/bin/index.js",
    "deploy": "pnpm run pages:build && pnpm exec wrangler pages deploy .vercel/output/static --project-name ably-link-sever2",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "next": "15.3.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "vercel": "47.0.4",
    "wrangler": "^4.0.0",
    "@cloudflare/workers-types": "^4.20260426.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.3.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
